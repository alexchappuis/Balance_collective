SECRET_KEY=replace-me-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Postgres on Railway will inject DATABASE_URL automatically.
# Locally, leave blank to fall back to sqlite.
DATABASE_URL=

# Gmail SMTP — use a Gmail App Password, not your real password.
EMAIL_HOST_USER=youraddress@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=Balance Collective &lt;youraddress@gmail.com&gt;
CONTACT_EMAIL=isa@balancecollective.co
